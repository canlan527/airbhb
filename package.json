{
  "name": "airbnb",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:web",
    "start": "pnpm dev:web",
    "build": "pnpm build:web",
    "preview": "pnpm preview:web",
    "dev:web": "pnpm --filter @airbhb/web dev",
    "build:web": "pnpm --filter @airbhb/web build",
    "preview:web": "pnpm --filter @airbhb/web preview",
    "dev:api": "pnpm --filter @airbhb/api start:dev",
    "build:api": "pnpm --filter @airbhb/api build",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:generate": "pnpm --filter @airbhb/api prisma generate",
    "prisma:migrate": "pnpm --filter @airbhb/api prisma migrate dev",
    "prisma:seed": "pnpm --filter @airbhb/api prisma db seed"
  }
}
